generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int              @id @default(autoincrement())
  firstName       String
  lastName        String
  role            Role             @default(EMPLOYEE)
  pin             String
  isFirstLogin    Boolean          @default(true)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  timeEntries     TimeEntry[]
  employeeProfile EmployeeProfile?
  auditLogs       AuditLog[]
}

model EmployeeProfile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  // Coordonnées (non chiffrées mais accès admin uniquement)
  email   String?
  phone   String?
  address String?

  // Données RH
  hireDate    DateTime? @db.Date
  activity    String?
  category    String?
  hourlyRate  Decimal?  @db.Decimal(8, 2)

  // Urgence
  emergencyContactName  String?
  emergencyContactPhone String?

  // Données sensibles chiffrées (AES-256-GCM, stockées base64)
  nirEncrypted                String?
  dateOfBirthEncrypted        String?
  placeOfBirthEncrypted       String?
  nationalityEncrypted        String?
  residencePermitTypeEncrypted String?
  residencePermitExpiryEncrypted String?
  lastMedicalVisitEncrypted   String?

  // RGPD
  consentGivenAt DateTime?
  informedAt     DateTime?
  dataRetentionUntil DateTime?

  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  action    String
  targetId  Int?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Chantier {
  id          Int         @id @default(autoincrement())
  name        String
  address     String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  timeEntries TimeEntry[]
}

model TimeEntry {
  id         Int      @id @default(autoincrement())
  userId     Int
  chantierId Int
  date       DateTime @db.Date
  startTime  String
  endTime    String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  chantier   Chantier @relation(fields: [chantierId], references: [id])

  @@index([userId, date])
  @@index([chantierId])
}

enum Role {
  ADMIN
  EMPLOYEE
}
